<% layout("/layouts/boilerplate"); %>
<section class="services" id="services">
    <div class="container">

        <h2 class="section-title">My Services</h2>
        <p class="section-subtitle">
            I help build modern, scalable, and responsive web applications with clean UI and strong backend systems.
        </p>

        <div class="services-grid">

            <!-- Service 1 -->
            <div class="service-card">
                <h3>Full-Stack Web Development</h3>
                <p>
                    Building complete web applications using Node.js, Express.js, MongoDB, and modern frontend
                    technologies.
                </p>
            </div>

            <!-- Service 2 -->
            <div class="service-card">
                <h3>Backend Development & APIs</h3>
                <p>
                    Designing secure and scalable REST APIs, authentication systems, and server-side logic using Node.js
                    & Express.
                </p>
            </div>

            <!-- Service 3 -->
            <div class="service-card">
                <h3>Frontend Development</h3>
                <p>
                    Creating responsive and user-friendly interfaces using HTML, CSS, JavaScript, and modern UI design
                    principles.
                </p>
            </div>

            <!-- Service 4 -->
            <div class="service-card">
                <h3>Database Design</h3>
                <p>
                    Working with MongoDB and SQL to design efficient database structures for scalable applications.
                </p>
            </div>

            <!-- Service 5 -->
            <div class="service-card">
                <h3>API Integration</h3>
                <p>
                    Integrating third-party APIs and building dynamic features like maps, authentication, and cloud
                    services.
                </p>
            </div>

            <!-- Service 6 -->
            <div class="service-card">
                <h3>Responsive Web Design</h3>
                <p>
                    Ensuring applications work smoothly across all devices with mobile-first and responsive design
                    techniques.
                </p>
            </div>

        </div>

    </div>
</section>