<% layout("/layouts/boilerplate"); %>
<section class="projects" id="projects">
    <div class="container">

        <h2 class="section-title">My Projects</h2>
        <p class="section-subtitle">
            A collection of full-stack and frontend projects I’ve built while learning and practicing development.
        </p>
        <div class="d-flex justify-content-between align-items-center mb-4">
        
            <h5 class="mb-0">
                Total Projects:
                <span id="projectCount"></span>
            </h5>
            <% if(currUser && currUser.isAdmin){ %>
            <form method="get" action="/addproject" class="mb-0">
                <button type="submit" class="btn btn-primary">
                    Add Project
                </button>
            </form>
            <% } %>
        
        </div>
        
        <div class="projects-grid">
            
            
                <% projects.forEach((project, index)=> { %>
            
                    <div class="card <%= index >= 3 ? 'hidden-project' : '' %>">
                    
                        <!-- Carousel -->
                        <div id="carousel<%= project._id %>" class="carousel slide" data-bs-ride="carousel">
                    
                            <div class="carousel-inner">
                    
                                <% if(project.images && project.images.length){ %>
                    
                                    <% project.images.forEach((img,index)=>{ %>
                    
                                        <div class="carousel-item <%= index===0 ? 'active' : '' %>">
                                            <img src="<%= img %>" class="d-block w-100 card-img-top" alt="Project Image">
                                        </div>
                    
                                        <% }) %>
                    
                                            <% } else { %>
                    
                                                <div class="carousel-item active">
                                                    <img src="/images/default-project.jpg" class="d-block w-100 card-img-top"
                                                        alt="Default Image">
                                                </div>
                    
                                                <% } %>
                    
                            </div>
                    
                            <button class="carousel-control-prev" type="button" data-bs-target="#carousel<%= project._id %>"
                                data-bs-slide="prev">
                    
                                <span class="carousel-control-prev-icon"></span>
                    
                            </button>
                    
                            <button class="carousel-control-next" type="button" data-bs-target="#carousel<%= project._id %>"
                                data-bs-slide="next">
                    
                                <span class="carousel-control-next-icon"></span>
                    
                            </button>
                    
                        </div>
                    
                        <!-- Card Content -->
                        <div class="project-card">
                    
                            <div class="project-content">
                    
                                <h3>
                                    <%= project.title %>
                                </h3>
                    
                                <p>
                                    <%= project.description %>
                                </p>
                    
                                <div class="project-tags">
                                    <% project.technologies.forEach(tech=> { %>
                                        <span>
                                            <%= tech %>
                                        </span>
                                        <% }) %>
                                </div>
                    
                                <% if(project.projectLink){ %>
                                    <a href="<%= project.projectLink %>" class="project-btn">
                                        View Project
                                    </a>
                                    <% } %> 
                                <% if(currUser && currUser.isAdmin){ %>
                                <div class="d-flex gap-2 mt-3">
                                
                                    <a href="/projects/<%= project._id %>/editProject" class="btn btn-primary">
                                        Edit
                                    </a>
                                
                                    <form action="/projects/<%= project._id %>?_method=DELETE" method="POST"
                                        onsubmit="return confirm('Are you sure you want to delete this project?')">
                                
                                        <button class="btn btn-danger">
                                            Delete
                                        </button>
                                
                                    </form>
                                
                                </div>
                                <% } %>
                    
                            </div>
                    
                        </div>
                    
                    </div>
            
                    <% }) %>
            
            </div>
 
