<% layout("/layouts/boilerplate"); %>
<section class="projects" id="projects">
    <div class="container">

        <h2 class="section-title">My Projects</h2>
        <p class="section-subtitle">
            A collection of full-stack and frontend projects I’ve built while learning and practicing development.
        </p>

        <div class="projects-grid">

            <!-- Project 1 -->
            <div class="project-card">
                <div class="project-content">
                    <h3>Wanderlust</h3>
                    <p>
                        A full-stack travel listing platform inspired by Airbnb with authentication, CRUD operations,
                        image uploads, and interactive maps.
                    </p>

                    <div class="project-tags">
                        <span>Node.js</span>
                        <span>Express</span>
                        <span>MongoDB</span>
                        <span>REST API</span>
                    </div>

                    <a href="#" class="project-btn">View Project</a>
                </div>
            </div>

            <!-- Project 2 -->
            <div class="project-card">
                <div class="project-content">
                    <h3>Spotify Clone</h3>
                    <p>
                        A responsive frontend clone of Spotify with modern UI layout, sidebar navigation, and reusable
                        components.
                    </p>

                    <div class="project-tags">
                        <span>HTML</span>
                        <span>CSS</span>
                        <span>Flexbox</span>
                    </div>

                    <a href="#" class="project-btn">View Project</a>
                </div>
            </div>

            <!-- Project 3 -->
            <div class="project-card">
                <div class="project-content">
                    <h3>Portfolio Website</h3>
                    <p>
                        Personal developer portfolio showcasing skills, projects, and contact information with a
                        responsive design.
                    </p>

                    <div class="project-tags">
                        <span>HTML</span>
                        <span>CSS</span>
                        <span>JavaScript</span>
                    </div>

                    <a href="#" class="project-btn">View Project</a>
                </div>
            </div>

        </div>

    </div>
</section>