            A collection of full-stack and frontend projects I’ve built while learning and practicing development.
        </p>

        <div class="projects-grid">

            <!-- Project 1 -->
            <div class="card">
                <div id="serviceCarousel1" class="carousel slide" data-bs-ride="carousel">
            
                    <div class="carousel-indicators">
                        <button type="button" data-bs-target="#serviceCarousel1" data-bs-slide-to="0" class="active"></button>
                        <button type="button" data-bs-target="#serviceCarousel1" data-bs-slide-to="1"></button>
                        <button type="button" data-bs-target="#serviceCarousel1" data-bs-slide-to="2"></button>
                    </div>
            
                    <div class="carousel-inner">
            
                        <div class="carousel-item active">
                            <img src="https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?auto=format&fit=crop&w=800&q=80"
                                class="d-block w-100 card-img-top" alt="Server and APIs">
                        </div>
            
                        <div class="carousel-item">
                            <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=800&q=80"
                                class="d-block w-100 card-img-top" alt="Backend Development">
                        </div>
            
                        <div class="carousel-item">
                            <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=800&q=80"
                                class="d-block w-100 card-img-top" alt="Cloud Backend">
                        </div>
            
                    </div>
            
                    <button class="carousel-control-prev" type="button" data-bs-target="#serviceCarousel1" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
            
                    <button class="carousel-control-next" type="button" data-bs-target="#serviceCarousel1" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
            
                </div>
            <div class="project-card">
                <div class="project-content">
                    <h3>Wanderlust</h3>
                    <p>
                        A full-stack travel listing platform inspired by Airbnb with authentication, CRUD operations,
                        image uploads, and interactive maps.
                    </p>

                    <div class="project-tags">
                        <span>Node.js</span>
                        <span>Express</span>
                        <span>MongoDB</span>
                        <span>REST API</span>
                    </div>

                    <a href="#" class="project-btn">View Project</a>
                </div>
            </div>
