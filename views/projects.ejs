<script>
    document.addEventListener("DOMContentLoaded", () => {
        const total = document.querySelectorAll(".projects-grid .card").length;
        document.getElementById("projectCount").textContent = total;
    });
</script>
<script>
document.addEventListener("DOMContentLoaded", () => {

    const showBtn = document.getElementById("showBtn");

        if (!showBtn) return;

        const hiddenCards = document.querySelectorAll(".projects-grid .card");

        let expanded = false;

    showBtn.addEventListener("click", () => {

            hiddenCards.forEach((card, index) => {

                if (index >= 3) {

                    if (expanded) {
                        card.classList.add("hidden-project");
                    } else {
                        card.classList.remove("hidden-project");
                    }

                }

            });

        expanded = !expanded;

        showBtn.textContent = expanded
        ? "Show Less Projects"
        : "Show More Projects";

    });

});
</script>



